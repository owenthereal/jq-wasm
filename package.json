{
  "name": "jq-wasm",
  "version": "2.0.0-jq-1.8.2",
  "description": "A high-performance jq wrapper using Emscripten and WebAssembly.",
  "type": "commonjs",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owenthereal/jq-wasm.git"
  },
  "homepage": "https://github.com/owenthereal/jq-wasm#readme",
  "bugs": {
    "url": "https://github.com/owenthereal/jq-wasm/issues"
  },
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "inline": [
        "dist/inline.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "workerd": {
        "types": "./dist/edge.d.mts",
        "import": "./dist/edge.mjs"
      },
      "edge-light": {
        "types": "./dist/edge.d.mts",
        "import": "./dist/edge.mjs"
      },
      "browser": {
        "types": "./dist/browser.d.mts",
        "import": "./dist/browser.mjs"
      },
      "node": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.cjs"
        }
      },
      "default": {
        "types": "./dist/browser.d.mts",
        "import": "./dist/browser.mjs"
      }
    },
    "./inline": {
      "import": {
        "types": "./dist/inline.d.mts",
        "default": "./dist/inline.mjs"
      },
      "require": {
        "types": "./dist/inline.d.ts",
        "default": "./dist/inline.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "fetch:jq-latest": "curl -s https://api.github.com/repos/jqlang/jq/releases/latest 2>/dev/null | jq -r .tag_name || echo 'Error: Failed to fetch jq version' >&2 && exit 1",
    "fetch:jq-master": "git ls-remote https://github.com/jqlang/jq.git master | awk '{print substr($1, 1, 7)}' || echo 'Error: Failed to fetch jq master sha' >&2 && exit 1",
    "build": "JQ_BRANCH=$(npm run fetch:jq-latest --silent) script/build",
    "build:debug": "JQ_BRANCH=$(npm run fetch:jq-latest --silent) BUILD_TYPE=debug script/build",
    "build:master": "JQ_BRANCH=$(npm run fetch:jq-master --silent) script/build",
    "build:dist": "tsup && mkdir -p dist/build && cp src/build/jq.wasm dist/build/jq.wasm",
    "release": "JQ_BRANCH=$(npm run fetch:jq-latest --silent) script/release",
    "release:master": "JQ_BRANCH=$(npm run fetch:jq-master --silent) script/release",
    "tsc": "tsc",
    "test": "vitest run --project node",
    "lint": "eslint src/",
    "lint:package": "publint && attw --pack .",
    "smoke": "script/smoke",
    "test:workers": "vitest run --project workers"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist/"
  ],
  "keywords": [
    "jq",
    "wasm",
    "emscripten",
    "webassembly",
    "typescript",
    "javascript"
  ],
  "author": "Owen Ou",
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@types/node": "^22.10.6",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^6.1.1",
    "prettier": "^3.4.2",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "typescript": "^5.3.2",
    "vitest": "~3.2.4"
  },
  "overrides": {
    "ws": "^8.21.0",
    "minimatch": "^10.2.5",
    "brace-expansion": "^2.0.2",
    "picomatch": "^4.0.4",
    "esbuild": "^0.28.1",
    "wrangler": "^4.60.0"
  }
}
