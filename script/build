#!/bin/sh
# shellcheck shell=dash

set -e

# Check required environment variables
if [ -z "$JQ_BRANCH" ]; then
    echo "ERROR: JQ_BRANCH environment variable is required."
    echo "Usage: JQ_BRANCH=jq-1.7.1 script/build"
    exit 1
fi

# Set defaults
BUILD_TYPE=${BUILD_TYPE:-release}

echo "Building jq $JQ_BRANCH $BUILD_TYPE build"

# Run Docker build
docker build \
    --build-arg JQ_BRANCH="$JQ_BRANCH" \
    --build-arg BUILD_TYPE="$BUILD_TYPE" \
    --output src/build \
    .

# Typecheck, then emit JS + types with tsup. tsup does not copy binary assets,
# so copy the wasm into dist/build afterward.
npm run tsc
rm -rf dist
npx tsup
mkdir -p dist/build
cp src/build/jq.wasm dist/build/jq.wasm
if [ ! -f dist/build/jq.wasm ]; then
    echo "Error: dist/build/jq.wasm missing after build"
    exit 1
fi
