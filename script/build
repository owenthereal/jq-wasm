#!/bin/sh
# shellcheck shell=dash

set -e

# Check required environment variables
if [ -z "$JQ_BRANCH" ]; then
    echo "ERROR: JQ_BRANCH environment variable is required."
    echo "Usage: JQ_BRANCH=jq-1.7.1 script/build"
    exit 1
fi

# Set defaults
BUILD_TYPE=${BUILD_TYPE:-release}

echo "Building jq $JQ_BRANCH $BUILD_TYPE build"

# Run Docker build
docker build \
    --build-arg JQ_BRANCH="$JQ_BRANCH" \
    --build-arg BUILD_TYPE="$BUILD_TYPE" \
    --output src/build \
    .

# Compile TypeScript.
tsc

# Emit the Workers-compatible ESM edge entry.
tsc -p tsconfig.edge.json
mv dist/edge-esm/edge.js dist/edge.mjs
mv dist/edge-esm/jq-api.js dist/jq-api.mjs
sed 's/"\.\/jq-api\.js"/".\/jq-api.mjs"/' dist/edge.mjs > dist/edge.mjs.tmp
mv dist/edge.mjs.tmp dist/edge.mjs
rm -rf dist/edge-esm
rm -f dist/edge.js

# TypeScript copies the generated JavaScript glue files, but it does not copy
# the generated wasm asset that jq-wasm/edge imports.
mkdir -p dist/build
cp src/build/jq.wasm dist/build/jq.wasm

if [ ! -s dist/build/jq.wasm ]; then
    echo "Error: Failed to copy wasm asset from src/build/jq.wasm"
    exit 1
fi
