#!/bin/sh
# shellcheck shell=dash
# Smoke-tests the built dist against real runtimes/bundlers.
# Assumes the package is already built (npx tsup) and dist/build/jq.wasm copied.
set -e

echo "ESM import + run..."
node --input-type=module -e "
  import { raw } from 'jq-wasm';
  const r = await raw('{\"a\":1}', '.a');
  if (r.stdout.trim() !== '1') throw new Error('ESM raw failed: ' + JSON.stringify(r));
  console.log('  ESM OK');
"

echo "CJS require + run..."
node -e "
  const { raw } = require('jq-wasm');
  raw('{\"a\":1}', '.a').then((r) => {
    if (r.stdout.trim() !== '1') throw new Error('CJS raw failed: ' + JSON.stringify(r));
    console.log('  CJS OK');
  }).catch((e) => { console.error(e); process.exit(1); });
"

# Bundling the browser entry for the browser platform must succeed with no
# unresolved Node built-ins (path/url/fs) leaking in from the shared chunk, and
# must preserve the jq.wasm reference for the consumer's bundler to resolve.
echo "Bundler (esbuild bundles the browser build for the browser platform)..."
OUT=$(mktemp -d)
npx esbuild dist/browser.mjs --bundle --platform=browser --format=esm \
  --loader:.wasm=copy --outfile="$OUT/browser.js" >/dev/null
if [ -s "$OUT/browser.js" ] && grep -qi 'wasm' "$OUT/browser.js"; then
  echo "  bundler OK (browser bundle built, wasm reference preserved)"
else
  echo "  FAIL: browser bundle empty or missing wasm reference"
  exit 1
fi

echo "Inline entry (self-contained ESM, runs with no external wasm)..."
node --input-type=module -e "
  import { raw } from 'jq-wasm/inline';
  const r = await raw('{\"a\":1}', '.a');
  if (r.stdout.trim() !== '1') throw new Error('inline raw failed: ' + JSON.stringify(r));
  console.log('  inline ESM runs OK');
"

# The inline workaround that index.ts points missing-wasm users at must resolve
# for require() too, not just import — CJS consumers hit that path as well.
echo "Inline entry (self-contained CJS, require + run)..."
node -e "
  const { raw } = require('jq-wasm/inline');
  raw('{\"a\":1}', '.a').then((r) => {
    if (r.stdout.trim() !== '1') throw new Error('inline CJS raw failed: ' + JSON.stringify(r));
    console.log('  inline CJS runs OK');
  }).catch((e) => { console.error(e); process.exit(1); });
"

# The embedded build must bundle under esbuild with no external wasm dependency.
echo "Inline entry self-contained under esbuild..."
INLINE_OUT=$(mktemp -d)
npx esbuild dist/inline.mjs --bundle --platform=browser --format=esm --outfile="$INLINE_OUT/inline.js" >/dev/null
INLINE_SIZE=$(wc -c < "$INLINE_OUT/inline.js")
if [ "$INLINE_SIZE" -gt 1000000 ]; then
  echo "  inline esbuild OK (${INLINE_SIZE} bytes, wasm embedded, no external asset)"
else
  echo "  FAIL: inline bundle too small ($INLINE_SIZE) — wasm not embedded?"
  exit 1
fi

# A Node server bundled into a single file must keep working via the inline
# entry — the default entry's runtime fs read of jq.wasm would be lost there.
echo "Inline entry survives a single-file Node bundle (esbuild --platform=node, esm)..."
NODE_BUNDLE=$(mktemp -d)
cat > "$NODE_BUNDLE/entry.mjs" <<EOF
import { raw } from "$(pwd)/dist/inline.mjs";
const r = await raw('{"a":1}', ".a");
if (r.stdout.trim() !== "1") { console.error("FAIL", r); process.exit(1); }
console.log("  bundled Node (esm) OK");
EOF
npx esbuild "$NODE_BUNDLE/entry.mjs" --bundle --platform=node --format=esm --outfile="$NODE_BUNDLE/app.mjs" >/dev/null
node "$NODE_BUNDLE/app.mjs"

# Same guarantee for a CJS server bundle — the default require("jq-wasm")
# audience bundles to CJS (esbuild --format=cjs, ncc), so inline.cjs must
# bundle and run self-contained too.
echo "Inline entry survives a single-file Node bundle (esbuild --platform=node, cjs)..."
NODE_BUNDLE_CJS=$(mktemp -d)
cat > "$NODE_BUNDLE_CJS/entry.cjs" <<EOF
const { raw } = require("$(pwd)/dist/inline.cjs");
raw('{"a":1}', ".a").then((r) => {
  if (r.stdout.trim() !== "1") { console.error("FAIL", r); process.exit(1); }
  console.log("  bundled Node (cjs) OK");
}).catch((e) => { console.error(e); process.exit(1); });
EOF
npx esbuild "$NODE_BUNDLE_CJS/entry.cjs" --bundle --platform=node --format=cjs --outfile="$NODE_BUNDLE_CJS/app.cjs" >/dev/null
node "$NODE_BUNDLE_CJS/app.cjs"

echo "All smoke checks passed."
